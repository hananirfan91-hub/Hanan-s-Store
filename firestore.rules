rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'customer')
    //   - createdAt: string (optional)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - image: string (required)
    //   - category: string (required)
    //   - description: string (required)
    //   - isSale: boolean (optional)
    //   - salePrice: number (optional)
    //   - isNewArrival: boolean (optional)
    //   - sizes: array of numbers (optional)
    //   - createdAt: string (optional)
    //
    // Collection: products/{productId}/reviews
    // Document ID: {reviewId}
    // Fields:
    //   - productId: string (required)
    //   - userId: string (required)
    //   - userEmail: string (required)
    //   - rating: number (required)
    //   - comment: string (required)
    //   - createdAt: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "hananirfan91@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser() {
      let data = request.resource.data;
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['admin', 'customer'];
    }

    function isValidProduct() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'price', 'image', 'category', 'description']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 2000 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             (!('isSale' in data) || data.isSale is bool) &&
             (!('salePrice' in data) || data.salePrice is number) &&
             (!('isNewArrival' in data) || data.isNewArrival is bool) &&
             (!('sizes' in data) || (data.sizes is list && data.sizes.size() < 50));
    }

    function isValidReview() {
      let data = request.resource.data;
      return data.keys().hasAll(['productId', 'userId', 'userEmail', 'rating', 'comment']) &&
             data.productId is string && data.productId.size() > 0 && data.productId.size() < 100 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.userEmail is string && data.userEmail.size() > 0 && data.userEmail.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() < 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser() && 
                    ((request.resource.data.role == 'customer') || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser() && 
                    ((request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidProduct();
      allow update: if isAdmin() && isValidProduct();
      allow delete: if isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && isValidReview();
        allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidReview();
        allow delete: if isAdmin() || isOwner(resource.data.userId);
      }
    }
  }
}
