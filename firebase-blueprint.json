{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "isSale": { "type": "boolean" },
        "salePrice": { "type": "number" },
        "isNewArrival": { "type": "boolean" },
        "sizes": {
          "type": "array",
          "items": { "type": "number" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "image", "category", "description"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "userEmail", "rating", "comment"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores all products available in the store"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Stores reviews for a specific product"
    }
  }
}
